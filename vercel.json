{
	"version": 2,
	"builds": [
		{
			"src": "website/package.json",
			"use": "@vercel/next"
		}
	],
	"rewrites": [
		{
			"source": "/ph/static/(.*)",
			"destination": "https://eu-assets.i.posthog.com/static/$1"
		},
		{
			"source": "/ph/(.*)",
			"destination": "https://eu.i.posthog.com/$1"
		}
	]
}
